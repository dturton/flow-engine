# PostgreSQL
DATABASE_URL=postgresql://flowengine:flowengine@localhost:5432/flowengine

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO
S3_BUCKET=flow-engine
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000

# BullMQ
BULLMQ_QUEUE=flow-runs

# API
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*
LOG_LEVEL=info

# Worker
WORKER_CONCURRENCY=3
MAX_CONCURRENT_STEPS=5
STEP_TIMEOUT_MS=30000
CONTEXT_TTL_SECONDS=86400

# AWS credentials for MinIO (used by @aws-sdk/client-s3)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
